# ============================================================
# Aigen Python AI Service - Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================

# --- Application ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8100
APP_DEBUG=true

# --- DashScope (Alibaba Cloud LLM) ---
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- Redis (shared with Java for session/token validation) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Java Core Service (internal communication) ---
JAVA_CORE_BASE_URL=http://127.0.0.1:8080
JAVA_CORE_INTERNAL_SECRET=your-internal-secret-key

# --- Pexels API (image search) ---
PEXELS_API_KEY=your-pexels-api-key

# --- Code output directory (shared volume with Java) ---
CODE_OUTPUT_ROOT_DIR=./output
